enum StatusPesanan {
  MENUNGGU
  DIPROSES
  SELESAI
  BATAL
}

enum ModePesanan {
  ONLINE
  OFFLINE
}

model Pesanan {
  id                Int             @id @default(autoincrement()) @db.UnsignedInt
  id_pelanggan      Int             @db.UnsignedInt
  created_at        DateTime        @default(now())
  updated_at        DateTime        @updatedAt

  jenis_layanan     String
  nama_file         String?
  catatan_pesanan   String?
  nilai_pesanan     Float
  uang_diterima     Float?
  kembalian         Float?

  status            StatusPesanan   @default(MENUNGGU)
  mode_pesanan      ModePesanan     @default(ONLINE)

  sisi_cetak        String          @default("SATU_SISI")
  gramasi           String          @default("80gr")
  metode_pengiriman String          @default("AMBIL")
  ongkir            Float?
  alamat_pengiriman String?

  midtrans_order_id String?         @unique
  payment_status    String?
  snap_token        String?

  /* Foreign Key Relations */
  pelanggan         Pelanggan       @relation(fields: [id_pelanggan], references: [id])
  barangTerbeli     BarangTerbeli[]

  @@map("pesanan")
}