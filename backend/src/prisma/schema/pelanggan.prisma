model Pelanggan {
  id               Int            @id @default(autoincrement()) @db.UnsignedInt
  created_at       DateTime       @default(now())
  updated_at       DateTime       @updatedAt

  nama_lengkap     String
  nomor_telepon    String
  alamat           String?        @db.Text

  /* Foreign Key Relations */
  akunPelanggan    AkunPelanggan?
  pesanan          Pesanan[]

  @@map("pelanggan")
}
