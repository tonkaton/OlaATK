{
  "name": "olaatk-backend",
  "type": "module",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "start": "node dist/index.js",
    "start:dev": "nodemon",
    "compile": "tsc --project ./tsconfig.json",
