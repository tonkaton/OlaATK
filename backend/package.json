    "cors": "^2.8.5",
    "dotenv": "^17.2.3",
    "express": "^5.2.1",
    "reflect-metadata": "^0.2.2"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "^25.0.9",
    "concurrently": "^9.2.1",
    "nodemon": "^3.1.11",
    "prisma": "^7.2.0",
    "typescript": "^5.9.3"
  }
