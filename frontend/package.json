{
  "name": "olaatk-frontend",
  "private": true,
  "workspaces": ["admin", "user"],
  "scripts": {
    "dev:user": "npm -w user run dev",
    "dev:admin": "npm -w admin run dev",
    "dev:all": "concurrently \"npm -w user run dev\" \"npm -w admin run dev\"",
    "build:user": "npm -w user run build",
    "build:admin": "npm -w admin run build"
  },
  "devDependencies": {
    "concurrently": "^8.2.0"
  }
}